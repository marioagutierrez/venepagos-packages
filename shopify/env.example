# Shopify App
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app-url.com
SHOPIFY_SCOPES=write_payment_gateways,read_orders

# VenePagos API
VENEPAGOS_API_URL=https://api.venepagos.com
VENEPAGOS_API_KEY=your_venepagos_api_key
VENEPAGOS_MERCHANT_ID=your_merchant_id

# Checkout display mode: popup | newTab | redirect
VENEPAGOS_CHECKOUT_MODE=redirect

# Server
PORT=3000
NODE_ENV=development
